# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Provider selection ─────────────────────────────────────────────────────
# "azure" or "openai" — auto-detected if not set
LLM_PROVIDER=azure

# ── Azure OpenAI ───────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01
# Deployment name as shown in Azure AI Studio (e.g. "gpt-4o-mini-deploy")
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ── Plain OpenAI (alternative) ────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Google (future) ───────────────────────────────────────────────────────
# GOOGLE_API_KEY=...

# ── Langfuse (LLM observability) ──────────────────────────────────────────
# Keys are auto-provisioned on first boot via LANGFUSE_INIT_* in
# docker/langfuse/compose.yml — no manual UI steps needed.
# Run `make langfuse-up` (or `make stack-up`) and these will work immediately.
LANGFUSE_PUBLIC_KEY=pk-lf-aobench-local-dev-pub01
LANGFUSE_SECRET_KEY=sk-lf-aobench-local-dev-sec01
LANGFUSE_BASE_URL=http://localhost:3000

# ── Leaderboard API ────────────────────────────────────────────────────────
# Password for POST /admin/rebuild (HTTP Basic Auth, username ignored)
LEADERBOARD_ADMIN_PASS=change-me

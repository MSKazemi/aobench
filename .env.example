# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Provider selection ─────────────────────────────────────────────────────
# "azure" or "openai" — auto-detected if not set
LLM_PROVIDER=azure

# ── Azure OpenAI ───────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01
# Deployment name as shown in Azure AI Studio (e.g. "gpt-4o-mini-deploy")
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ── Plain OpenAI (alternative) ────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Google (future) ───────────────────────────────────────────────────────
# GOOGLE_API_KEY=...

# ── Langfuse (LLM observability) ──────────────────────────────────────────
# Get keys from http://localhost:3000 → Settings → API Keys
# Run: make langfuse-up  to start the local Langfuse server
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Either variable name is accepted (Langfuse UI shows LANGFUSE_BASE_URL)
LANGFUSE_BASE_URL=http://localhost:3000
# LANGFUSE_HOST=http://localhost:3000  # alternative, same effect
